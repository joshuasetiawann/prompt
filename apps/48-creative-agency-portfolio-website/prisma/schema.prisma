// Auto-generated for Studio Nova Creative Agency Portfolio Website. Edit prisma/schema.prisma to evolve the data model.
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  passwordHash String?
  name String
  role String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id String @id @default(cuid())
  title String
  category String?
  summary String?
  cover String?
  content String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id String @id @default(cuid())
  name String
  email String @unique
  company String?
  message Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id String @id @default(cuid())
  name String
  role String?
  photo String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
