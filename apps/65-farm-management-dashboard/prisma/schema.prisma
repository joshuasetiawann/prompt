// Auto-generated for AgriTrack Farm Management Dashboard. Edit prisma/schema.prisma to evolve the data model.
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  passwordHash String?
  name String
