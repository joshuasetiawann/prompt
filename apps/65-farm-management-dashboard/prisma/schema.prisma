  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id String @id @default(cuid())
  fieldId String?
  field Field? @relation("Task_field_Field", fields: [fieldId], references: [id], onDelete: Cascade, onUpdate: Cascade)
