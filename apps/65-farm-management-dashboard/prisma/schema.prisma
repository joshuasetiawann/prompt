}

model Field {
  id String @id @default(cuid())
  name String
  areaHa String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  crops Crop[] @relation("Crop_field_Field")
  tasks Task[] @relation("Task_field_Field")
  inputUsages InputUsage[] @relation("InputUsage_field_Field")
}

model Crop {
  id String @id @default(cuid())
  fieldId String?
  field Field? @relation("Crop_field_Field", fields: [fieldId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  name String
  plantedOn String?
  expectedHarvest String?
  stage Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  yields Yield[] @relation("Yield_crop_Crop")
