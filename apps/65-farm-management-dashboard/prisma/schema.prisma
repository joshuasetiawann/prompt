  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([fieldId])
  @@index([assigneeId])
}

model Input {
  id String @id @default(cuid())
  name String
  unit String?
  stock Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  inputUsages InputUsage[] @relation("InputUsage_input_Input")
